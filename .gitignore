# ============================================================
# v3-only toy-project repo. Track ONLY: code + docs + figures
# (+ slim result logs). Everything heavy or personal is excluded.
# ============================================================

# --- model weights / checkpoints (huge, >100MB, reproducible) ---
*.safetensors
*.bin
*.gguf
*.pt
*.pth
**/checkpoints/
**/checkpoints_pt/
**/checkpoint-*/
**/global_step_*/

# --- datasets (re-downloadable / re-generatable) ---
data/
**/data/
*.parquet

# --- big eval dumps + per-chunk partials (verbose) ---
*_verbose.json
**/partials/
**/k128_merged/

# --- models dir + logs + caches ---
models/
**/logs/
*.log
__pycache__/
*.pyc
.venv/
venv/

# --- abandoned / unrelated / tooling top-level dirs (v3-only repo) ---
/v1/
/v2/
/aws/
/scripts_local/
/python课程/

# --- personal / PII (NEVER commit) ---
*.pdf
*.docx
*.doc
resume_chen.*
陈乙坤*
**/image.png
**/image copy*.png
**/extracted_photo*
/v3/_resume_qa_latest/
**/_edge_profile*/
/v3/_edit_resume.py
/v3/*resume*

