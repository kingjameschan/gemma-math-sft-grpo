!/v3/E2_sft/outputs/lr5e-4_step130_combined.png
/v3/E2_sft/tools/*
!/v3/E2_sft/tools/_paper_style_panels.py
!/v3/E2_sft/tools/_plot_step130_combined.py

/v3/E5_grpo/audit/
/v3/E5_grpo/train/
/v3/E5_grpo/r16_grpo/
